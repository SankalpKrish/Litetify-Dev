# Litetify environment template — copy to `.env` and fill in.
# NOTE: Litetify is a PUBLIC desktop app. It uses Authorization Code + PKCE.
# There is NO client secret. Never add one here.
#
# Each user supplies their own Spotify Client ID (created at
# https://developer.spotify.com/dashboard). At runtime the app also lets the
# user enter this in Settings, so this file is optional / for dev convenience.

# Spotify application Client ID (public — safe to expose in a desktop app).
VITE_SPOTIFY_CLIENT_ID=

# Loopback redirect the app listens on. Must EXACTLY match a redirect URI
# registered in the Spotify dashboard. Loopback IP literal is required
# (localhost / http hostnames were removed from Spotify OAuth on 2025-11-27).
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:14523/callback
